{
	"schemaVersion": 1,
	"id": "tsc-client",
	"version": "${version}",
	"name": "Traffic Stop Client",
	"description": "Welcome to Highway 2b2t",
	"authors": [
		"awaboi"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Awaboi-Codes/TrafficStopClient"
	},
	"license": "MIT",
	"icon": "assets/tsc-client/icon.png",
